{
    "name": "chortke/platform",
    "description": "پلتفرم کسب درآمد آنلاین چرتکه",
    "type": "project",
    "require": {
        "php": ">=8.2",
        "phpmailer/phpmailer": "^7.0",
        "ext-pdo": "*",
        "ext-mysqli": "*"
    },
    "autoload": {
        "psr-4": {
            "Core\\": "core/",
            "App\\": "app/"
        },
        "files": [
            "helpers/config_helper.php",
            "helpers/url_helper.php",
            "helpers/auth_helper.php",
            "helpers/view_helper.php",
            "helpers/csrf_helper.php",
            "helpers/password_helper.php",
            "helpers/response_helper.php",
            "helpers/date_helper.php",
            "helpers/file_helper.php",
            "helpers/logging.php",
            "helpers/site_helper.php",
            "helpers/device_helper.php",
            "helpers/security.php",
            "helpers/label_helpers.php",
            "helpers/captcha_helper.php",
            "helpers/notifications.php",
            "helpers/rate_limit.php",
            "helpers/fraud_helper.php",
            "helpers/feature_flag_helpers.php"
        ]
    },
    "config": {
        "optimize-autoloader": true
    }
}